# Local AgentRail API configuration.
#
# Copy this file to .env before running `npm start`.
# The OSS demo does not require private API keys or paid services.

AGENTRAIL_HOST=127.0.0.1
AGENTRAIL_PORT=3000
AGENTRAIL_PUBLIC_BASE_URL=http://127.0.0.1:3000

# Optional: persist task lifecycle SSE/webhook events across local restarts.
# Leave empty for in-memory demo storage.
AGENTRAIL_EVENT_STORE_PATH=

# Local SDK examples use this placeholder when no auth store is configured.
AGENTRAIL_API_KEY=ar_local_demo_key

# Observability: set to "json" to emit structured JSON log lines per operation.
# Fields: ts, level, operation, agentId, taskId, provider, idempotencyKey,
#         estimatedTokens, durationMs, statusCode, retryCount, fallbackUsed, errorClass
AGENTRAIL_LOG_FORMAT=text
AGENTRAIL_OBSERVABILITY=true

# Fallback switch: set to "true" to put AgentRail into passive fallback mode.
# In fallback mode all task-lifecycle API routes return 503 with a structured
# response that agents can detect to revert to direct GitHub / Paperclip APIs.
# Set back to "false" (or remove) to restore normal operation.
AGENTRAIL_FALLBACK_MODE=false

# Waitlist confirmation email — Brevo (preferred, free tier: 300/day, no domain verification).
# Set BREVO_API_KEY to send confirmation emails via Brevo (https://brevo.com).
# Free plan: 300 emails/day, 9,000/month. Verify your sender email at brevo.com.
# BREVO_FROM_EMAIL must be a verified sender address in your Brevo account.
# Store only in deployment secrets; never commit to the repo.
BREVO_API_KEY=
BREVO_FROM_EMAIL=waitlist@agentrail.dev
BREVO_FROM_NAME=AgentRail

# Waitlist confirmation email — SendGrid (fallback, free tier, single sender verification).
# Set SENDGRID_API_KEY to send confirmation emails via SendGrid (https://sendgrid.com).
# Free plan: 100 emails/day. Verify one sender address at sendgrid.com/ui/account/sender-verification.
# Set SENDGRID_FROM_EMAIL to the verified sender address.
# Store only in deployment secrets; never commit to the repo.
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=AgentRail <waitlist@agentrail.dev>

# Waitlist confirmation email — Resend (fallback, requires verified domain).
# Used only when SENDGRID_API_KEY is not set.
# Requires a verified sending domain; set RESEND_FROM_EMAIL to match.
# Store only in deployment secrets; never commit to the repo.
RESEND_API_KEY=
RESEND_FROM_EMAIL=AgentRail <waitlist@agentrail.dev>

# Waitlist confirmation email — generic webhook fallback.
# Used only when neither SENDGRID_API_KEY nor RESEND_API_KEY is set.
# POST /waitlist calls this URL with { email, name, id, createdAt } after a new signup.
# Leave empty to skip email delivery (response will include confirmationEmail: "skipped").
WAITLIST_EMAIL_WEBHOOK_URL=

# Optional Bearer token sent in the Authorization header to the webhook above.
# Store only in deployment secrets; never commit to the repo.
WAITLIST_EMAIL_WEBHOOK_TOKEN=
