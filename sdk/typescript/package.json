{
  "name": "@agentrail-core/sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for the AgentRail Task Lifecycle API",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "test": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "agentrail",
    "sdk",
    "agent",
    "task-lifecycle"
  ],
  "license": "Apache-2.0",
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "typescript": "^5.7.0"
  }
}
