# Example environment for AgentRail live sandbox validation.
# Copy to .env.sandbox and set the GITHUB_TOKEN before running live smoke tests.
#
# Do not commit .env.sandbox or any file containing secrets.
#
# To run the live sandbox smoke:
#   cp .env.sandbox.example .env.sandbox
#   # edit .env.sandbox and add your GITHUB_TOKEN
#   export $(grep -v '^#' .env.sandbox | xargs)
#   npm run smoke:sandbox:live
#
# Required GitHub permissions for the sandbox repo:
#   Contents: read/write
#   Pull requests: read/write
#   Issues: read/write
#   Actions: read
#   Checks/statuses: read

AGENTRAIL_SANDBOX_OWNER=oxnw
AGENTRAIL_SANDBOX_REPO=agentrail-e2e-sandbox
AGENTRAIL_SANDBOX_ISSUE_NUMBER=2
AGENTRAIL_SANDBOX_HEAD_BRANCH=agentrail-live-e2e-20260504192023
AGENTRAIL_SANDBOX_BASE_BRANCH=main
AGENTRAIL_SANDBOX_PULL_NUMBER=3
AGENTRAIL_SANDBOX_HEAD_SHA=2b6ac22e49c804bdd8d2c714ff14892d2ff8cea9

# Set this in .env.sandbox (not committed):
# GITHUB_TOKEN=ghp_...

# Optional — only set if you want to test the ship/merge step on a disposable PR.
# AGENTRAIL_SANDBOX_ALLOW_SHIP=true
